{
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "auto",

  "vueIndentScriptAndStyle": false,
  "htmlWhitespaceSensitivity": "ignore",

  "singleAttributePerLine": false
}
